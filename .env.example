# SvelteKit adapter-node body size limit (default: 512KB)
# Set high enough to accommodate file uploads (MAX_FILE_SIZE defaults to 2GB)
BODY_SIZE_LIMIT=Infinity

# Max file upload size in bytes (default: 2GB)
# MAX_FILE_SIZE=2147483648

# Max total file storage per pad in bytes (default: 1GB)
# MAX_PAD_FILE_QUOTA=1073741824
